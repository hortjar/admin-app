# ─── Universal Admin / Auth Server ─────────────────────────────────────────────
# HTTP port the server (API + built SPA) listens on.
PORT=9000

# Public URL the server is reachable at. Used as the JWT `iss` (issuer) claim and
# advertised in the OpenID discovery document. Downstream apps must trust this.
ISSUER=http://localhost:9000

# Postgres connection string.
DATABASE_URL=postgres://admin:admin@localhost:5433/universal_admin

# Comma-separated list of allowed CORS origins for the admin SPA + downstream apps.
CORS_ORIGINS=http://localhost:9000,http://localhost:5173

# ─── Signing keys ──────────────────────────────────────────────────────────────
# The server signs access tokens with an RS256 private key and publishes the
# matching public key at /.well-known/jwks.json. On first boot, if no key exists
# in the database, one is generated automatically. You can also pin a key here
# (PEM, base64-encoded) to keep it stable across fresh databases.
# SIGNING_KEY_PEM_BASE64=

# Access token lifetime (seconds). Default 15 minutes.
ACCESS_TOKEN_TTL=900
# Refresh token lifetime (seconds). Default 30 days.
REFRESH_TOKEN_TTL=2592000

# ─── Bootstrap admin ───────────────────────────────────────────────────────────
# On first boot the seed creates this super-admin if no users exist.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-now

# ─── Cross-subdomain SSO cookie ──────────────────────────────────────────────────
# The refresh token is also issued as an HttpOnly cookie. Set COOKIE_DOMAIN to a
# parent domain so every app under it can silently obtain a session (log in once).
#   e.g. COOKIE_DOMAIN=.hortjar.cz  → shared across *.hortjar.cz
# Leave empty for a host-only cookie (single domain, still enables cookie auth).
ENABLE_AUTH_COOKIES=true
COOKIE_DOMAIN=
# Secure requires HTTPS (default: on in production). Must be true when SameSite=none.
COOKIE_SECURE=false
# "lax" is fine across sibling subdomains of one parent; "none" for cross-site.
COOKIE_SAMESITE=lax
# When COOKIE_DOMAIN is set, list every app origin here so credentialed CORS works:
#   CORS_ORIGINS=https://auth.hortjar.cz,https://filesync.hortjar.cz,https://checklist.hortjar.cz
