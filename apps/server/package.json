{
  "name": "@universal-admin/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot --env-file=../../.env src/index.ts",
    "start": "bun run src/index.ts",
    "migrate": "bun run --env-file=../../.env src/db/migrate.ts",
    "seed": "bun run --env-file=../../.env src/db/seed.ts",
    "generate": "drizzle-kit generate",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "@elysiajs/static": "^1.4.2",
    "@universal-admin/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "jose": "^6.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.2"
  }
}
